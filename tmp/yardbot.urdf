<robot name="yardbot">
  <!--
    Yardbot URDF — placeholder geometry for TF tree.
    Real dimensions TBD once chassis is designed.

    Current assumptions:
      - base_link is at ground level, robot centre
      - camera_link is 0.5m above base_link, slightly forward
      - Camera is an Intel RealSense D455 (roughly 124mm × 26mm × 29mm)

    When you add a pan mount later, replace the fixed camera joint
    with a continuous/revolute joint driven by a joint_state_publisher.
  -->
  <!-- ═══════════════════════════════════════════
       PARAMETERS  (easy to tweak in one place)
       ═══════════════════════════════════════════ -->
  <!-- m, vertical    -->
  <!-- height above ground -->
  <!-- ═══════════════════════════════════════════
       MATERIALS
       ═══════════════════════════════════════════ -->
  <material name="dark_grey">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>
  <material name="light_grey">
    <color rgba="0.7 0.7 0.7 1.0"/>
  </material>
  <material name="realsense_blue">
    <color rgba="0.1 0.2 0.8 1.0"/>
  </material>
  <!-- ═══════════════════════════════════════════
       BASE LINK
       The origin of the robot; sits at ground level
       at the geometric centre of the footprint.
       ═══════════════════════════════════════════ -->
  <link name="base_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0.1"/>
      <geometry>
        <box size="0.7 0.5 0.2"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0.1"/>
      <geometry>
        <box size="0.7 0.5 0.2"/>
      </geometry>
    </collision>
    <inertial>
      <!-- Rough placeholder mass/inertia for a ~15 kg robot body -->
      <mass value="15.0"/>
      <origin xyz="0 0 0.1"/>
      <inertia ixx="0.30" ixy="0" ixz="0" iyy="0.40" iyz="0" izz="0.60"/>
    </inertial>
  </link>
  <!-- ═══════════════════════════════════════════
       CAMERA MOUNT LINK
       A small post representing the camera bracket.
       When you add a pan servo, this becomes the
       rotating part and gets its own joint.
       ═══════════════════════════════════════════ -->
  <link name="camera_mount_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.05" radius="0.015"/>
      </geometry>
      <material name="light_grey"/>
    </visual>
  </link>
  <joint name="camera_mount_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_mount_link"/>
    <!-- Position: forward of centre, at camera height, plus half the mount height -->
    <origin rpy="0 0 0" xyz="0.1 0.0 0.5"/>
  </joint>
  <!-- ═══════════════════════════════════════════
       CAMERA LINK
       The physical camera body. The D455 "depth
       optical frame" is published by the RealSense
       driver relative to this link.
       ═══════════════════════════════════════════ -->
  <link name="camera_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.124 0.026 0.029"/>
      </geometry>
      <material name="realsense_blue"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.124 0.026 0.029"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.072"/>
      <!-- D455 ~72g -->
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="camera_joint" type="fixed">
    <parent link="camera_mount_link"/>
    <child link="camera_link"/>
    <!--
      No additional offset; camera_link sits at camera_mount_link.
      The RealSense driver will publish the transforms from
      camera_link → camera_depth_optical_frame etc. automatically.
    -->
    <origin rpy="0 0 0" xyz="0 0 0"/>
  </joint>
  <!--
    ═══════════════════════════════════════════════════════
    FUTURE: PAN JOINT
    When you have a pan mount, replace camera_joint above
    with something like:

    <joint name="camera_pan_joint" type="continuous">
      <parent link="camera_mount_link"/>
      <child  link="camera_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>   <!/-/- rotate around Z = pan \-\->
      <limit effort="1.0" velocity="1.0"/>
    </joint>

    Then publish the joint angle via joint_states and
    robot_state_publisher will compute the TF automatically.
    ═══════════════════════════════════════════════════════
  -->
</robot>
